{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 80,
  "tabWidth": 4,
  "useTabs": false,
  "semi": true,
  "singleQuote": true,
  "trailingComma": "all",
  "insertFinalNewline": true,
  "singleAttributePerLine": true,
  "bracketSpacing": false,
  "ignorePatterns": ["packages/*/dist/**", "packages/*/.wrangler/**"]
}